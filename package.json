{
  "name": "agentstack-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "cli",
    "pipeline"
  ],
  "scripts": {
    "build": "tsc -b cli pipeline",
    "clean": "tsc -b cli pipeline --clean",
    "validate:starter": "npm run build && tsx scripts/validate-starter.ts",
    "smoke:phase2": "npm run build && tsx scripts/smoke-phase2.ts",
    "pipeline:collect": "tsx pipeline/src/collect.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22"
  }
}
