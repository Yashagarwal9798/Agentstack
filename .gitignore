# dependencies / build output
node_modules/
dist/
*.tsbuildinfo

# secrets — never commit keys
.env
.env.*

# local runtime state (never part of the repo)
.supermemory/
.agentstack/

# local dev tooling (installed skills for the coding agent, not product code)
.agents/
.claude/
skills-lock.json

# transient pipeline debug output (cursors.json and pending.json ARE committed)
catalog/state/candidates.json
catalog/state/*.log
